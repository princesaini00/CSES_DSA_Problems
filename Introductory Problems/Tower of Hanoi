import java.io.*;
import java.util.*;
 
import static java.lang.System.out;
 
public class Main {
    public static void solve(FastScanner fs, PrintWriter out) {
        int n = fs.nextInt();
        List<int[]> list = new ArrayList<>();
        int moves = toh(n, 1, 2, 3, list);
        out.println(moves);
        for(int[] pair : list) {
            out.println(pair[0] + " " + pair[1]);
        }
        return;
    }
 
    private static int toh(int n, int from, int aux, int to, List<int[]> list) {
        if(n == 0) return 0;
        if(n == 1) {
            list.add(new int[] {from, to});
            return 1;
        }
 
        int count = 0;
        count += toh(n-1, from, to, aux, list);
        list.add(new int[] {from, to});
        count++;
        count += toh(n-1, aux, from, to, list);
 
        return count;
    }
 
    public static void main(String[] args) {
        FastScanner fs = new FastScanner();
        PrintWriter out = new PrintWriter(System.out);
 
        int t = 1;
        while (t-- > 0) {
            solve(fs, out);
        }
 
        out.flush();
        out.close();
    }
 
    static class FastScanner {
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        StringTokenizer st = new StringTokenizer("");
 
        String next() {
            while (!st.hasMoreTokens()) {
                try {
                    String line = br.readLine();
                    if (line == null) return "";
                    st = new StringTokenizer(line);
                } catch (IOException e) {
                    e.printStackTrace();
                }
            }
            return st.nextToken();
        }
 
        int nextInt() { return Integer.parseInt(next()); }
        long nextLong() { return Long.parseLong(next()); }
        double nextDouble() { return Double.parseDouble(next()); }
        String nextLine() {
            String str = "";
            try { str = br.readLine(); }
            catch (IOException e) { e.printStackTrace(); }
            return str;
        }
    }
}
